# Database
DATABASE_URL=postgresql://memory_user:password@postgres:5432/memory_engine

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=memory_chunks

# LLM Configuration
LLM_PROVIDER=openai          # openai|anthropic|google|ollama
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini        # gpt-4o-mini|claude-sonnet-4|gemini-2.0-flash

# Embedding (optional)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Scheduler
ADVISOR_CRON=0 8 * * *       # Daily at 8 AM
ADVISOR_TIMEZONE=Asia/Seoul

# Web Research (optional)
WEB_RESEARCH_ENABLED=false   # Enable DuckDuckGo search

# Notifications (optional)
NOTIFY_WEBHOOK=              # Webhook URL for notifications
TELEGRAM_BOT_TOKEN=          # Telegram bot token
TELEGRAM_CHAT_ID=            # Telegram chat ID

# User
DEFAULT_USER_ID=default

# Server
PORT=8003
