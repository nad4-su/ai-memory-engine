# ===========================
# AI Memory Engine Configuration
# ===========================

# --- LLM Provider (Required) ---
# Options: openai, anthropic, google, ollama
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# --- Embedding (Optional, defaults to LLM_PROVIDER) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Fallback Provider (Optional) ---
# Uncomment to enable fallback when primary provider fails
# LLM_FALLBACK_PROVIDER=anthropic
# LLM_FALLBACK_API_KEY=sk-ant-xxx
# LLM_FALLBACK_MODEL=claude-sonnet-4-20250514

# --- Schedule ---
# Cron format: minute hour day month weekday
PROFILER_CRON=0 0 * * *        # Daily at midnight (analyze interests)
ADVISOR_CRON=0 8 * * *         # Daily at 8 AM (generate suggestions)
ADVISOR_TIMEZONE=Asia/Seoul

# --- Notifications (Optional) ---
# Generic webhook for notifications
# NOTIFY_WEBHOOK=https://hooks.example.com/xxx

# Telegram notifications
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# --- Data Sources (Optional) ---
# Obsidian vault path (local or mounted)
# OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Bookmark API (e.g., Raindrop.io, Linkding)
# BOOKMARK_API_URL=https://api.raindrop.io/rest/v1/raindrops/0
# BOOKMARK_API_KEY=your-api-key

# --- System ---
# PostgreSQL password (change this!)
POSTGRES_PASSWORD=change_me_please

# Frontend port (default 3080 to avoid conflict with port 3000)
FRONTEND_PORT=3080

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
